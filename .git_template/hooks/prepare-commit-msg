COMMIT_MSG=$1

BRANCH_NAME=`git rev-parse --abbrev-ref HEAD`
PREFIX=''

if [[ "${BRANCH_NAME}" == *"dev"* ]]; then
    PREFIX=`echo ${BRANCH_NAME} | cut -d '/' -f2 | cut -d '/' -f1`
fi

if [[ ${PREFIX} == '' ]]; then
    echo "" >> $COMMIT_MSG
else
    echo "[$PREFIX] $(cat $COMMIT_MSG)"  > $COMMIT_MSG
fi
